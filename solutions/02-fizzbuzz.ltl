// Solution 2: FizzBuzz

fn fizzbuzz(n: int) -> string {
    match (n % 3, n % 5) {
        (0, 0) => "FizzBuzz",
        (0, _) => "Fizz",
        (_, 0) => "Buzz",
        _      => "${n}"
    }
}

fn main() {
    for i in 1..=20 {
        print("${i}: ${fizzbuzz(i)}")
    }

    assert_eq(fizzbuzz(1), "1")
    assert_eq(fizzbuzz(3), "Fizz")
    assert_eq(fizzbuzz(5), "Buzz")
    assert_eq(fizzbuzz(15), "FizzBuzz")
    assert_eq(fizzbuzz(7), "7")

    print("✓ All tests passed!")
}

main()
