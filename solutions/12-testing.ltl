// Solution 12 — Testing

fn is_palindrome(s: string) -> bool {
    let chars = s.chars() |> collect()
    chars == chars |> reverse() |> collect()
}

fn count_words(s: string) -> int {
    s.split_whitespace() |> filter(w => !w.is_empty()) |> count()
}

fn fizzbuzz(n: int) -> string {
    match (n % 3, n % 5) {
        (0, 0) => "FizzBuzz",
        (0, _) => "Fizz",
        (_, 0) => "Buzz",
        _      => n.to_string(),
    }
}

test "is_palindrome — true cases" {
    assert_eq(is_palindrome("racecar"), true)
    assert_eq(is_palindrome("level"),   true)
    assert_eq(is_palindrome("a"),       true)
    assert_eq(is_palindrome(""),        true)
}

test "is_palindrome — false cases" {
    assert_eq(is_palindrome("hello"), false)
    assert_eq(is_palindrome("ab"),    false)
}

test "fizzbuzz table" {
    let cases = [
        (1,  "1"),
        (3,  "Fizz"),
        (5,  "Buzz"),
        (15, "FizzBuzz"),
        (16, "16"),
    ]
    for (n, expected) in cases {
        assert_eq(fizzbuzz(n), expected, "fizzbuzz(${n})")
    }
}

test "count_words — empty" {
    assert_eq(count_words(""),        0)
    assert_eq(count_words("   "),     0)
}

test "count_words — multi-space" {
    assert_eq(count_words("hello world"),      2)
    assert_eq(count_words("  foo  bar  baz  "), 3)
}
