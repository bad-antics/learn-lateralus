// Exercise 12 — Testing
// Run: lateralus test exercises/12-testing.ltl

fn is_palindrome(s: string) -> bool {
    let chars = s.chars() |> collect()
    chars == chars |> reverse() |> collect()
}

fn count_words(s: string) -> int {
    s.split_whitespace() |> filter(w => !w.is_empty()) |> count()
}

fn fizzbuzz(n: int) -> string {
    match (n % 3, n % 5) {
        (0, 0) => "FizzBuzz",
        (0, _) => "Fizz",
        (_, 0) => "Buzz",
        _      => n.to_string(),
    }
}

