fn main() {
    print(safe_div(10.0, 2.0))        // ok(5.0)
    print(safe_div(10.0, 0.0))        // err(DivisionByZero)
    print(safe_sqrt(4.0))             // ok(2.0)
    print(safe_sqrt(-1.0))            // err(NegativeSquareRoot)
    print(sqrt_of_div(16.0, 4.0))     // ok(2.0)
    print(sqrt_of_div(16.0, 0.0))     // err(DivisionByZero)
    print(parse_floats("1.0,2.5,3"))  // ok([1.0, 2.5, 3.0])
    print(parse_floats("1.0,abc"))    // err(...)
    print("Exercise 11 complete!")
}

main()
