// Exercise 11 — Error Handling
// Run: lateralus run exercises/11-error-handling.ltl

enum MathError {
    DivisionByZero,
    Overflow,
    NegativeSquareRoot,
}

impl MathError {
    fn to_string(self) -> string {
        match self {
            MathError.DivisionByZero     => "division by zero",
            MathError.Overflow           => "overflow",
            MathError.NegativeSquareRoot => "negative square root",
        }
    }
}

